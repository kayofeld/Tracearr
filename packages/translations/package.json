{
  "name": "@tracearr/translations",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mobile": {
      "types": "./dist/mobile.d.ts",
      "react-native": "./src/mobile.ts",
      "import": "./dist/mobile.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-locales.js",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "clean": "rm -rf dist .turbo",
    "check": "tsx scripts/check-translations.ts"
  },
  "dependencies": {
    "i18next": "^26.3.6",
    "react-i18next": "^17.0.9"
  },
  "devDependencies": {
    "tsx": "^4.23.1",
    "typescript": "^6.0.0",
    "vite": "^8.0.5"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "sideEffects": false
}
